{
  "root": true,
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": { "jsx": false }
  },
  "plugins": ["react-hooks"],
  "globals": {
    "beforeEach": "readonly",
    "afterEach": "readonly",
    "beforeAll": "readonly",
    "afterAll": "readonly",
    "describe": "readonly",
    "it": "readonly",
    "test": "readonly",
    "expect": "readonly",
    "vi": "readonly"
  },
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "build/",
    "docs/",
    "logs/",
    "../dist/"
  ],
  "rules": {
    "no-undef": "error",
    "no-unused-vars": ["warn", {
      "args": "none",
      "varsIgnorePattern": "^_",
      "argsIgnorePattern": "^_",
      "caughtErrors": "none"
    }],
    "no-empty": ["warn", {"allowEmptyCatch": true}],
    "no-constant-condition": ["warn", {"checkLoops": false}],
    "no-case-declarations": "warn",
    "no-useless-escape": "warn",
    "no-prototype-builtins": "warn",
    "react-hooks/rules-of-hooks": "warn",
    "react-hooks/exhaustive-deps": "warn"
  }
}
