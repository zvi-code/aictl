	// }
	//  
	// ```
	"javascript.inlayHints.propertyDeclarationTypes.enabled": false,

	// This setting is deprecated. Use `js/ts.inlayHints.variableTypes.enabled` instead.
	// Enable/disable inlay hints for implicit variable types:
	// ```typescript
