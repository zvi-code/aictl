		"#86592d",
		"#ffffff"
	],

	// Status bar color when in VisualLine mode.
	"vim.statusBarColors.visualline": [
		"#005f87",
		"#ffffff"
	],

	// Automatically apply the global flag, `/g`, to substitute commands. When set to true, use `/g` to mean only first match should be replaced.
	"vim.substituteGlobalFlag": false,

	// Background color of substituted text when `#editor.inccommand#` is enabled. Uses `#editor.findMatchColor#` from current theme if undefined.
	"vim.substitutionColor": null,

	// Foreground color of substituted text when `#editor.inccommand#` is enabled.
	"vim.substitutionTextColor": null,

	// Enable the [Surround](https://github.com/tpope/vim-surround) plugin for Vim.
	"vim.surround": true,

	// Enable last/next movements for bracket objects.
	"vim.targets.bracketObjects.enable": true,

	// Enable [targets.vim](https://github.com/wellle/targets.vim#quote-text-objects) plugin (not fully implemented yet).
	"vim.targets.enable": false,

	// Whether to use default Vim behavior when using `a` (e.g. `da'`) which include surrounding spaces, or not, as for other text objects.
	"vim.targets.smartQuotes.aIncludesSurroundingSpaces": true,

	// Whether to break through lines when using [n]ext/[l]ast motion, see [targets.vim#next-and-last-quote](https://github.com/wellle/targets.vim#next-and-last-quote).
	"vim.targets.smartQuotes.breakThroughLines": true,

	// Enable the smart quotes movements from [targets.vim](https://github.com/wellle/targets.vim#quote-text-objects).
	"vim.targets.smartQuotes.enable": true,

	// Width to word-wrap to when using `gq`.
	"vim.textwidth": 80,

	// Timeout in milliseconds for remapped commands.
	"vim.timeout": 1000,

	// Enable some Vim Ctrl key commands that override otherwise common operations, like `Ctrl+C`.
	"vim.useCtrlKeys": true,

	// Use system clipboard for unnamed register.
	"vim.useSystemClipboard": false,

	// Use key mappings from a `.vimrc` file.
	"vim.vimrc.enable": false,

