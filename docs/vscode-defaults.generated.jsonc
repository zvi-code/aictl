		"commits": true,
		"worktrees": true,
		"branches": true,
		"remotes": true,
		"stashes": true,
		"tags": true,
		"contributors": true,
		"repositories": true,
		"fileHistory": false,
		"launchpad": false,
		"searchAndCompare": false
	},

	// Specifies whether to show avatar images instead of commit (or status) icons in the _Search & Compare_ view
	"gitlens.views.searchAndCompare.avatars": true,

